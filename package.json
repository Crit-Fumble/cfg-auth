{
  "name": "@crit-fumble/auth",
  "version": "1.0.0",
  "type": "module",
  "description": "Crit-Fumble JWT mint/verify + JWE cookie decrypt — single-source auth contract between core-server and core-browser",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Crit-Fumble/cfg-auth.git"
  },
  "homepage": "https://github.com/Crit-Fumble/cfg-auth",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "clean": "rimraf dist",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "prepare": "husky",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@panva/hkdf": "^1.2.1",
    "jose": "^6.2.2"
  },
  "devDependencies": {
    "@auth/core": "^0.41.2",
    "@swc/core": "^1.15.33",
    "@swc/jest": "^0.2.37",
    "@types/jest": "^29.5.14",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
