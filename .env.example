# ─────────────────────────────────────────────────────────────────────────────
# @crit-fumble/auth environment variables
#
# This is a published library (npm.pkg.github.com/@crit-fumble/auth). It does
# not read any env vars at runtime — secrets are passed as arguments to
# mintSessionJwt / verifySessionJwt / decryptSessionCookie. Consuming apps
# (cfg-core-server, cfg-core-browser) own the env-var plumbing.
#
# This file documents the two values you may need at the development edges:
# install-time auth, and the AUTH_SECRET shape.
# ─────────────────────────────────────────────────────────────────────────────

# ── Install ──────────────────────────────────────────────────────────────────
# Required to `npm install` because GitHub Packages requires auth even for
# public packages. Locally: `export NODE_AUTH_TOKEN=$(gh auth token)`.
# CI: GitHub Actions sets this from `${{ secrets.GITHUB_TOKEN }}`.
NODE_AUTH_TOKEN=

# ── Tests ────────────────────────────────────────────────────────────────────
# Tests pass secrets directly (no process.env reads). This var is documented
# only because consumers will see `AUTH_SECRET` in src/ comments — that's the
# secret the consuming app must supply at runtime when calling the library.
# 32+ random bytes, e.g. `openssl rand -base64 32`.
AUTH_SECRET=
